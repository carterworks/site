---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<style>
  .inline-avatar {
    height: 1lh;
    width: 1lh;
    display: inline-block;
    margin-inline-end: 0.1225rem;
    border-radius: 100%;
    vertical-align: text-bottom;
  }
</style>

<img class="inline-avatar" src={src} alt={alt} />
