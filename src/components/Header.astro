---
import { DEV } from "astro:env/client";
---

<header class="stack">
  <hgroup class="stack">
    <a
      href="/"
      class="stack"
    >
      <h1>
        I'm {DEV && "(dev mode) "}Carter.
      </h1>
      <p>A software developer.</p>
    </a>
  </hgroup>
  <ul>
    <li>
      <a
        href="https://mastodon.social/@literallyacar"
        rel="me"
        aria-label="Mastodon"
        >Mastodon</a
      >
    </li>
    <li>
      <a
        href="https://github.com/carterworks"
        aria-label="GitHub"
        >GitHub</a
      >
    </li>
    <li>
      <a
        href="https://www.linkedin.com/in/thatcartermcbride/"
        aria-label="LinkedIn"
        >LinkedIn</a
      >
    </li>
  </ul>
</header>
