---
import { DEV } from "astro:env/client";

const possibleSubtitles = [
  "A software developer.",
  "A dad.",
  "A grump.",
  "An enjoyer of simple things.",
  "carter.works? I sure hope he does!",
  "A sepia tone enthusiast.",
  "A crust eaten in peace is better than a banquet partaken in anxiety.",
];
const randomIndex = Math.floor(Math.random() * possibleSubtitles.length);
const initialSubtitle =
  possibleSubtitles.at(randomIndex % possibleSubtitles.length) ?? "";
---

<script defer is:inline define:vars={{ possibleSubtitles }}>
  function randomSubtitle() {
    const $headingSubtitle = document.getElementById("heading-subtitle");
    if (!$headingSubtitle || possibleSubtitles.length === 0) {
      return;
    }const randomIndex = Math.floor(Math.random() * possibleSubtitles.length);
    const subtitle =
      possibleSubtitles.at(randomIndex % possibleSubtitles.length) ?? "";
    $headingSubtitle.textContent = subtitle;
  }
  randomSubtitle();
</script>
<header class="stack">
  <hgroup class="stack">
    <a
      href="/"
      class="stack"
    >
      <h1>
        I'm {DEV && "(dev mode) "}Carter.
      </h1>
      <p id="heading-subtitle">{initialSubtitle}</p>
    </a>
  </hgroup>
  <ul role="list">
    <li role="listitem">
      <a
        href="https://mastodon.social/@literallyacar"
        rel="me"
        aria-label="Mastodon"
        >Mastodon</a
      >
    </li>
    <li role="listitem">
      <a
        href="https://github.com/carterworks"
        aria-label="GitHub"
        >GitHub</a
      >
    </li>
    <li role="listitem">
      <a
        href="https://www.linkedin.com/in/thatcartermcbride/"
        aria-label="LinkedIn"
        >LinkedIn</a
      >
    </li>
  </ul>
</header>
