---
import { render } from "astro:content";
import {
  getPostDescription,
  getPostTitle,
  getPublishedPosts,
} from "../../lib/blog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateLong } from "../../lib/date";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
const frontmatter = {
  ...entry.data,
  articleClass: remarkPluginFrontmatter.articleClass,
};
const pubDateISO = frontmatter.pubDate.toISOString();
const humanFriendlyDate = formatDateLong(frontmatter.pubDate);
const title = getPostTitle(entry);
const pageTitle = `${title} | carter.works`;
const description = getPostDescription(entry);
---

<BaseLayout title={pageTitle}>
  <Fragment slot="head">
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="article" />
    <meta property="og:article:published_time" content={pubDateISO} />
    <meta property="og:article:author" content="Carter McBride" />
    <style is:global>
      article blockquote {
        border-inline-start: 2px solid black;
        padding-inline-start: var(--size-xs);
      }
    </style>
  </Fragment>
  <article class:list={["stack", frontmatter.articleClass]}>
    <header class="stack">
      <h1>
        {frontmatter.draft && "Rough Draft: "}{title}
      </h1>
      <p>
        <time datetime={pubDateISO}>{humanFriendlyDate}</time>
      </p>
    </header>
    <Content />
  </article>
</BaseLayout>
