---
import { getPostTitle, getPublishedPosts } from "../../lib/blog";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateLong, toISODateString } from "../../lib/date";

const posts = await getPublishedPosts();
const blogPostCount = posts.length;
const blogPostLabel =
  new Intl.PluralRules("en-US").select(blogPostCount) === "one"
    ? "blog post"
    : "blog posts";
const mostRecentBlogPost = posts[0];
const title = "All blog posts | carter.works";
const description = "A software engineer's blog? How original.";
---

<BaseLayout title={title}>
  <Fragment slot="head">
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <style>
      ol {
        list-style: none;
      }
    </style>
  </Fragment>
  <section>
    <p>
      He has written {blogPostCount}
      {blogPostLabel}. The most recent was <a
        href={`/blog/${mostRecentBlogPost.id}/`}
        ><q>{getPostTitle(mostRecentBlogPost)}</q></a
      >
      and it was written on <time
        datetime={toISODateString(mostRecentBlogPost.data.pubDate)}
      >
        {formatDateLong(mostRecentBlogPost.data.pubDate)}
      </time>. You can get updates <a href="/blog/atom.xml">via Atom.</a>
    </p>
  </section>
  <section class="stack">
    <h1>All blog posts</h1>
    <ol class="stack">
      {
        posts.map((post) => (
          <li>
            <article>
              <h2>
                <a href={`/blog/${post.id}/`}>
                  {post.data.draft && "Rough Draft: "}
                  {getPostTitle(post)}
                </a>
              </h2>
              <time datetime={toISODateString(post.data.pubDate)}>
                {formatDateLong(post.data.pubDate)}
              </time>
            </article>
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>
