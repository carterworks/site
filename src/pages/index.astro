---
import { getEntry } from "astro:content";
import MarkdownIt from "markdown-it";
import { getPublishedPosts } from "../lib/blog";
import RssFeed from "../components/RssFeed.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticlePreview from "../components/ArticlePreview.astro";

const parser = new MarkdownIt();
const homeEntry = await getEntry("data", "home");

if (!homeEntry) {
  throw new Error("Missing home content data");
}

const { home } = homeEntry.data;
const introHtml = parser.renderInline(home.intro.body);
const recentPosts = await getPublishedPosts();
---

<BaseLayout title={home.title}>
  <Fragment slot="head">
    <meta
      name="description"
      property="og:description"
      content={home.description}
    />
  </Fragment>
  <main class="stack">
    <section>
      <h2>{home.intro.heading}</h2>
      <Fragment set:html={introHtml} />
    </section>
    <section class="stack">
      <h2>{home.projects.heading}</h2>
      <ul role="list">
        {
          home.projects.items.map((project) => (
            <li role="listitem">
              <a href={project.url}>
                {project.title}
                {project.description && `, ${project.description}`}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="stack">
      <h2>
        <a href={home.socialFeed.url}>{home.socialFeed.heading}</a>
      </h2>
      <RssFeed
        url={home.socialFeed.feedUrl}
        count={home.socialFeed.count}
      />
    </section>
    {
      recentPosts.length > 0 && (
        <section class="stack">
          <h2>
            <a href="/blog/">Blog posts</a>
            <a
              href="/blog/feed.xml"
              title="RSS feed"
              aria-label="RSS feed"
            >
              (RSS)
            </a>
          </h2>
          <ul role="list">
            {recentPosts.map((post) => (
              <li role="listitem">
                <ArticlePreview post={post} />
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</BaseLayout>
