---
import MarkdownIt from "markdown-it";
import { getPublishedPosts } from "../lib/blog";
import RssFeed from "../components/RssFeed.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticlePreview from "../components/ArticlePreview.astro";

const parser = new MarkdownIt();
const home = {
  title: "👋 I'm Carter.",
  description: "Front-end dev. Father. Young grump. Simple things enjoyer.",
  intro: {
    heading: "Who?",
    body: "Still figuring things out. Right now: a dad, a tired man, a code plumber on the Web, [a complector](https://youtu.be/SxdOUGdseq4), a researcher, a homebody, a reader, a eater (not a foodie), and [a disciple of Christ](https://churchofjesuschrist.org).",
  },
  projects: {
    heading: "Some things I made",
    items: [
      {
        title: "Yazzy",
        url: "https://yazzy.carter.works",
        description: "a site to bring reader mode to all the web.",
      },
      {
        title: "My personal RSS reader",
        url: "https://carterworks.github.io/rss-reader/",
        description: "",
      },
      {
        title: "Substack-to-epub scraper",
        url: "https://github.com/carterworks/substack-to-epub",
        description: "",
      },
      {
        title: "Experiments, what ifs, and prototypes",
        url: "https://tools.carter.works/",
        description: "",
      },
    ],
  },
  socialFeed: {
    heading: "Mastodon",
    url: "https://mastodon.social/@literallyacar",
    feedUrl: "https://mastodon.social/@literallyacar.rss",
    count: 2,
  },
};
const introHtml = parser.renderInline(home.intro.body);
const recentPosts = await getPublishedPosts();
---

<BaseLayout title={home.title}>
  <Fragment slot="head">
    <meta
      name="description"
      property="og:description"
      content={home.description}
    />
  </Fragment>
  <main class="stack">
    <section>
      <h2>{home.intro.heading}</h2>
      <Fragment set:html={introHtml} />
    </section>
    <section class="stack">
      <h2>{home.projects.heading}</h2>
      <ul role="list">
        {
          home.projects.items.map((project) => (
            <li role="listitem">
              <a href={project.url}>
                {project.title}
                {project.description && `, ${project.description}`}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="stack">
      <h2>
        <a href={home.socialFeed.url}>{home.socialFeed.heading}</a>
      </h2>
      <RssFeed
        url={home.socialFeed.feedUrl}
        count={home.socialFeed.count}
      />
    </section>
    {
      recentPosts.length > 0 && (
        <section class="stack">
          <h2>
            <a href="/blog/">Blog posts</a>
            <a
              href="/blog/feed.xml"
              title="RSS feed"
              aria-label="RSS feed"
            >
              (RSS)
            </a>
          </h2>
          <ul role="list">
            {recentPosts.map((post) => (
              <li role="listitem">
                <ArticlePreview post={post} />
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
</BaseLayout>
