      /** @type {Record<Hat, string>} */
      const HAT_LINES = {
        none: '',
        crown: '   \\^^^/    ',
        tophat: '   [___]    ',
        propeller: '    -+-     ',
        halo: '   (   )    ',
        wizard: '    /^\\     ',
        beanie: '   (___)    ',
        tinyduck: '    ,>      ',
      };

      /**
       * @param {CompanionBones} bones
       * @param {number} [frame=0]
       * @returns {string[]}
       */
      function renderSprite(bones, frame = 0) {
        const frames = BODIES[bones.species];
        const body = frames[frame % frames.length].map(line =>
          line.replaceAll('{E}', bones.eye),
        );
        const lines = [...body];
        if (bones.hat !== 'none' && !lines[0].trim()) {
          lines[0] = HAT_LINES[bones.hat];
        }
        if (!lines[0].trim() && frames.every(f => !f[0].trim())) lines.shift();
        return lines;
      }

      /**
       * @param {Species} species
       * @returns {number}
       */
      function spriteFrameCount(species) {
        return BODIES[species].length;
      }
      // #endregion

      // #region Companion Generation
      /** Mulberry32 — tiny seeded PRNG */
      function mulberry32(seed) {
        let a = seed >>> 0;
        return function () {
          a |= 0;
          a = (a + 0x6d2b79f5) | 0;
          let t = Math.imul(a ^ (a >>> 15), 1 | a);
          t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
        };
      }

      function hashString(s) {
        let h = 2166136261;
        for (let i = 0; i < s.length; i++) {
          h ^= s.charCodeAt(i);
          h = Math.imul(h, 16777619);
        }
        return h >>> 0;
      }

      function pick(rng, arr) {
        return arr[Math.floor(rng() * arr.length)];
      }

      /** @returns {Rarity} */
      function rollRarity(rng) {
        const total = Object.values(RARITY_WEIGHTS).reduce((a, b) => a + b, 0);
        let roll = rng() * total;
        for (const rarity of RARITIES) {
          roll -= RARITY_WEIGHTS[rarity];
          if (roll < 0) return rarity;
        }
        return 'common';
      }

      const RARITY_FLOOR = {
        common: 5,
        uncommon: 15,
        rare: 25,
        epic: 35,
        legendary: 50,
      };

      function rollStats(rng, rarity) {
        const floor = RARITY_FLOOR[rarity];
        const peak = pick(rng, STAT_NAMES);
        let dump = pick(rng, STAT_NAMES);
        while (dump === peak) dump = pick(rng, STAT_NAMES);

        /** @type {Record<StatName, number>} */
        const stats = {};
        for (const name of STAT_NAMES) {
          if (name === peak) {
            stats[name] = Math.min(100, floor + 50 + Math.floor(rng() * 30));
          } else if (name === dump) {
            stats[name] = Math.max(1, floor - 10 + Math.floor(rng() * 15));
          } else {
            stats[name] = floor + Math.floor(rng() * 40);
          }
        }
        return stats;
      }

      const SALT = 'friend-2026-401';

      /**
       * @param {() => number} rng
       * @returns {{ bones: CompanionBones, inspirationSeed: number }}
       */
      function rollFrom(rng) {
        const rarity = rollRarity(rng);
        /** @type {CompanionBones} */
        const bones = {
          rarity,
          species: pick(rng, SPECIES),
          eye: pick(rng, EYES),
          hat: rarity === 'common' ? 'none' : pick(rng, HATS),
          shiny: rng() < 0.01,
          stats: rollStats(rng, rarity),
        };
        return { bones, inspirationSeed: Math.floor(rng() * 1e9) };
      }

      /**
       * @param {string} seed
       * @returns {{ bones: CompanionBones, inspirationSeed: number }}
       */
      function rollWithSeed(seed) {
        return rollFrom(mulberry32(hashString(seed)));
      }

      /**
       * @param {string} userId
       * @returns {{ bones: CompanionBones, inspirationSeed: number }}
       */
      function roll(userId) {
        return rollFrom(mulberry32(hashString(userId + SALT)));
      }
      // #endregion

      // #region Theme Switcher

      // --- localStorage-backed signal abstraction ---
      const STORAGE_KEY = "buddy-creator-theme";
      const DEFAULT_THEME = "dark";

      /** @type {Set<(value: ThemeName) => void>} */
      const _themeListeners = new Set();
      let _themeValue = (() => {
        try {
          const stored = localStorage.getItem(STORAGE_KEY);
          return THEME_NAMES.includes(stored) ? stored : DEFAULT_THEME;
        } catch {
          return DEFAULT_THEME;
        }
      })();

      const themeSignal = {
        get: () => _themeValue,
        set: (/** @type {ThemeName} */ v) => {
          if (v === _themeValue) return;
          _themeValue = v;
          try { localStorage.setItem(STORAGE_KEY, v); } catch {}
          for (const fn of _themeListeners) fn(v);
        },
        subscribe: (/** @type {(value: ThemeName) => void} */ fn) => {
          _themeListeners.add(fn);
          return () => _themeListeners.delete(fn);
        },
      };

      /** Hook: subscribe a Preact component to the theme signal */
      function useTheme() {
        const [value, setValue] = useState(themeSignal.get);
        useEffect(() => themeSignal.subscribe(setValue), []);
        return [value, themeSignal.set];
      }

      // --- end signal abstraction ---

      const THEME_LABELS = {
        dark: "Dark",
        light: "Light",
        "dark-daltonized": "Dark (colorblind)",
        "light-daltonized": "Light (colorblind)",
      };

      function applyTheme(themeName) {
        const theme = getTheme(themeName);
        const root = document.documentElement;
        root.style.setProperty("--bg", theme.userMessageBackground);
        root.style.setProperty("--text", theme.text);
        root.style.setProperty("--claude", theme.claude);
        root.style.setProperty("--subtle", theme.subtle);
        root.style.setProperty("--inactive", theme.inactive);
      }

      function ThemeSwitcher() {
        const [selected, setSelected] = useTheme();

        const onChange = (e) => {
          const name = e.target.value;
          setSelected(name);
          applyTheme(name);
        };

        return html`
          <label class="flex items-center gap-2 text-sm">
            Theme
            <select
              value=${selected}
              onChange=${onChange}
              class="bg-[var(--bg)] text-[var(--text)] border border-[var(--inactive)] rounded px-2 py-1 text-sm transition-colors duration-300"
            >
              ${THEME_NAMES.map(
                (name) => html`
                  <option
                    key=${name}
                    value=${name}
                  >
                    ${THEME_LABELS[name]}
                  </option>
                `,
              )}
            </select>
          </label>
        `;
      }

      // Apply saved (or default) theme immediately
      applyTheme(themeSignal.get());
      // Also react to future signal changes (e.g. from other tabs)
      themeSignal.subscribe(applyTheme);

      render(
        html`<${ThemeSwitcher} />`,
        document.getElementById("theme-switcher"),
      );
      // #endregion

      // #region Buddy Creator App

      const IDLE_SEQUENCE = [0, 0, 0, 0, 1, 0, 0, 0, -1, 0, 0, 2, 0, 0, 0];
      const TICK_MS = 500;

      // Card inner width in monospace columns (inner = CARD_COLS, total = CARD_COLS + 2 for │ │)
      const CARD_COLS = 34;

      // Box-drawing chars
      const B = {
        tl: '┌', tr: '┐', bl: '└', br: '┘',
        h: '─', v: '│', lt: '├', rt: '┤',
      };

      /**
       * Use pretext to find max chars of `text` that fit in `maxPx` at given font.
       * Returns a truncated string (with ellipsis if needed).
       */
      function truncateToFit(text, font, maxPx) {
        try {
          const prepared = prepare(text, font);
          const { lineCount } = layout(prepared, maxPx, 100);
          if (lineCount <= 1) return text;
          // Binary search for the longest prefix that fits in one line
          let lo = 0, hi = text.length;
          while (lo < hi) {
            const mid = (lo + hi + 1) >> 1;
            const sub = text.slice(0, mid) + '…';
            const p = prepare(sub, font);
            if (layout(p, maxPx, 100).lineCount <= 1) lo = mid;
            else hi = mid - 1;
          }
          return text.slice(0, lo) + '…';
        } catch {
          // Fallback: simple char truncation
          return text.length > CARD_COLS - 4 ? text.slice(0, CARD_COLS - 5) + '…' : text;
        }
      }

      /** Pad/truncate string to exactly `n` chars */
      function pad(str, n) {
        if (str.length > n) return str.slice(0, n - 1) + '…';
        return str.padEnd(n);
      }

      /** Build the plain-text card lines (no color). Used for copy and as render source. */
      function buildCardText(bones, seed) {
        const w = CARD_COLS;
        const inner = w - 2; // inside the │ │
        const stars = RARITY_STARS[bones.rarity];
        const species = bones.species.toUpperCase() + (bones.shiny ? ' ✨' : '');
        const hatLabel = bones.hat !== 'none' ? bones.hat : '—';
        const spriteLines = renderSprite(bones, 0);
        const totalStats = Object.values(bones.stats).reduce((a, b) => a + b, 0);

        const lines = [];
        // Top
        lines.push(B.tl + B.h.repeat(w) + B.tr);
        // Species + stars
        lines.push(B.v + ' ' + pad(species, inner - stars.length) + stars + ' ' + B.v);
        // Rarity + traits
        const rarity = bones.rarity.toUpperCase();
        const traits = bones.eye + ' eyes / ' + hatLabel;
        lines.push(B.v + ' ' + pad(rarity, inner - traits.length) + traits + ' ' + B.v);
        // Separator
        lines.push(B.lt + B.h.repeat(w) + B.rt);
        // Sprite
        for (const sl of spriteLines) {
          // Center the sprite (sprites are ~12 wide)
          const leftPad = Math.max(0, Math.floor((inner - sl.length) / 2));
          const rightPad = Math.max(0, inner - leftPad - sl.length);
          lines.push(B.v + ' ' + ' '.repeat(leftPad) + sl + ' '.repeat(rightPad) + ' ' + B.v);
        }
        // Separator
        lines.push(B.lt + B.h.repeat(w) + B.rt);
        // Stats
        const BAR_W = 18;
        for (const name of STAT_NAMES) {
          const v = bones.stats[name];
          const filled = Math.round(v * BAR_W / 100);
          const bar = '█'.repeat(filled) + '░'.repeat(BAR_W - filled);
          const label = name.padEnd(10);
          lines.push(B.v + ' ' + label + bar + String(v).padStart(4) + ' ' + B.v);
        }
        // Separator
        lines.push(B.lt + B.h.repeat(w) + B.rt);
        // Footer
        const tot = 'TOT ' + totalStats;
        const seedStr = seed.length > inner - tot.length - 2
          ? seed.slice(0, inner - tot.length - 3) + '…'
          : seed;
        lines.push(B.v + ' ' + tot + ' '.repeat(inner - tot.length - seedStr.length) + seedStr + ' ' + B.v);
        // Bottom
        lines.push(B.bl + B.h.repeat(w) + B.br);

        return lines;
      }

      /** Animated card — renders box-drawing text with colored spans */
      function TradingCard({ bones, seed }) {
        const [tick, setTick] = useState(0);
        const [themeName] = useTheme();
        const theme = getTheme(themeName);
        const preRef = useRef(null);

        useEffect(() => {
          const id = setInterval(() => setTick(t => t + 1), TICK_MS);
          return () => clearInterval(id);
        }, []);

        const rarityColor = theme[RARITY_COLORS[bones.rarity]] || theme.text;
        const accentColor = bones.shiny ? theme.warning : rarityColor;

        // Use pretext to pick the best font size so the card fits nicely
        const cardText = useMemo(() => buildCardText(bones, seed).join('\n'), [bones, seed]);
        const fontSize = useMemo(() => {
          const family = '"Courier New", Consolas, monospace';
          for (let size = 16; size >= 10; size--) {
            try {
              const p = prepare(cardText, size + 'px ' + family);
              const { height } = layout(p, 600, Math.round(size * 1.4));
              // If it doesn't wrap (lineCount matches our line count), this size works
              if (height <= cardText.split('\n').length * size * 1.4 + 4) return size;
            } catch { continue; }
          }
          return 12;
        }, [cardText]);

        // Build the animated version (sprite frame changes per tick)
        const frameIdx = IDLE_SEQUENCE[tick % IDLE_SEQUENCE.length];
        const frame = frameIdx === -1 ? 0 : frameIdx;
        const animatedSprite = renderSprite(bones, frame);
        const blinkSprite = frameIdx === -1
          ? animatedSprite.map(l => l.replaceAll(bones.eye, '-'))
          : animatedSprite;

        // Rebuild card lines with the animated sprite frame
        const staticLines = useMemo(() => buildCardText(bones, seed), [bones, seed]);
        // Find the sprite region (between first and second separator)
        const sepIndices = [];
        staticLines.forEach((l, i) => { if (l.startsWith(B.lt)) sepIndices.push(i); });
        const spriteStart = sepIndices[0] + 1;
        const spriteEnd = sepIndices[1];
        const inner = CARD_COLS - 2;

        const displayLines = staticLines.map((line, i) => {
          if (i >= spriteStart && i < spriteEnd) {
            const si = i - spriteStart;
            if (si < blinkSprite.length) {
              const sl = blinkSprite[si];
              const leftPad = Math.max(0, Math.floor((inner - sl.length) / 2));
              const rightPad = Math.max(0, inner - leftPad - sl.length);
              return B.v + ' ' + ' '.repeat(leftPad) + sl + ' '.repeat(rightPad) + ' ' + B.v;
            }
          }
          return line;
        });

        // Color regions: header (lines 1-2), separators, sprite, stats, footer
        const coloredLines = displayLines.map((line, i) => {
          // Box chars in accent color, content varies
          if (i === 0 || i === displayLines.length - 1) {
            // Top/bottom border
            return html`<span style=${{ color: accentColor }}>${line}</span>`;
          }
          if (line.startsWith(B.lt)) {
            // Separator
            return html`<span style=${{ color: accentColor }}>${line}</span>`;
          }
          if (i === 1) {
            // Species + stars line
            const content = line.slice(2, -2);
            return html`<span style=${{ color: accentColor }}>${B.v}</span><span style=${{ color: accentColor, fontWeight: 'bold' }}> ${content} </span><span style=${{ color: accentColor }}>${B.v}</span>`;
          }
          if (i === 2) {
            // Rarity + traits line
            const content = line.slice(2, -2);
            return html`<span style=${{ color: accentColor }}>${B.v}</span><span style=${{ color: theme.inactive }}> ${content} </span><span style=${{ color: accentColor }}>${B.v}</span>`;
          }
          if (i >= spriteStart && i < spriteEnd) {
            // Sprite lines
            const content = line.slice(1, -1);
            return html`<span style=${{ color: accentColor }}>${B.v}</span><span style=${{ color: accentColor }}>${content}</span><span style=${{ color: accentColor }}>${B.v}</span>`;
          }
          if (i > sepIndices[1] && i < sepIndices[2]) {
            // Stat lines: label dim, bar in accent, value bright
            const raw = line.slice(2, -2); // inner content
            const label = raw.slice(0, 10);
            const bar = raw.slice(10, 28);
            const val = raw.slice(28);
            return html`<span style=${{ color: accentColor }}>${B.v}</span><span style=${{ color: theme.inactive }}> ${label}</span><span style=${{ color: accentColor }}>${bar}</span><span style=${{ color: theme.text, fontWeight: 'bold' }}>${val}</span><span style=${{ color: accentColor }}> ${B.v}</span>`;
          }
          // Footer or other
          const content = line.slice(1, -1);
          return html`<span style=${{ color: accentColor }}>${B.v}</span><span style=${{ color: theme.inactive }}>${content}</span><span style=${{ color: accentColor }}>${B.v}</span>`;
        });

        return html`
          <pre
            ref=${preRef}
            class="select-all leading-snug"
            style=${{
              fontFamily: '"Courier New", Consolas, monospace',
              fontSize: fontSize + 'px',
              lineHeight: '1.4',
              color: theme.text,
              background: theme.userMessageBackground,
              padding: '12px 16px',
              borderRadius: '8px',
              boxShadow: '0 2px 12px rgba(0,0,0,0.2)',
              display: 'inline-block',
            }}
          >${coloredLines.map((l, i) => html`${i > 0 ? '\n' : ''}${l}`)}</pre>
        `;
      }

      /** Copy card as plain text to clipboard */
      function copyCardAsText(bones, seed) {
        const text = buildCardText(bones, seed).join('\n');
        navigator.clipboard.writeText(text);
      }

      /** 10-char base32 random seed */
      function randomSeed() {
        const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';
        const bytes = crypto.getRandomValues(new Uint8Array(10));
        return Array.from(bytes, b => alphabet[b & 31]).join('');
      }

      /** Main app */
      function getSeedFromURL() {
        return new URLSearchParams(window.location.search).get('seed') || '';
      }

      function setSeedInURL(s) {
        const url = new URL(window.location);
        if (s) url.searchParams.set('seed', s);
        else url.searchParams.delete('seed');
        window.history.replaceState(null, '', url);
      }

      function BuddyCreator() {
        const initialSeed = useMemo(() => getSeedFromURL() || randomSeed(), []);
        const [seed, setSeed] = useState(initialSeed);
        const [result, setResult] = useState(() => {
          const { bones } = roll(initialSeed);
          return { bones, seed: initialSeed };
        });
        const [themeName] = useTheme();
        const theme = getTheme(themeName);
        const [copied, setCopied] = useState(false);

        useEffect(() => { setSeedInURL(initialSeed); }, []);

        const generate = useCallback(() => {
          const s = seed.trim() || randomSeed();
          if (!seed.trim()) setSeed(s);
          setSeedInURL(s);
          const { bones } = roll(s);
          setResult({ bones, seed: s });
          setCopied(false);
        }, [seed]);

        const randomize = useCallback(() => {
          const s = randomSeed();
          setSeed(s);
          setSeedInURL(s);
          const { bones } = roll(s);
          setResult({ bones, seed: s });
          setCopied(false);
        }, []);

        const onKeyDown = useCallback((e) => {
          if (e.key === 'Enter') generate();
        }, [generate]);

        const onCopy = useCallback(() => {
          if (!result) return;
          copyCardAsText(result.bones, result.seed);
          setCopied(true);
          setTimeout(() => setCopied(false), 2000);
        }, [result]);

        return html`
          <div class="flex flex-col gap-6">
            <p class="text-sm" style=${{ color: theme.inactive }}>
              Enter any seed to generate a buddy card. Same seed = same card. Screenshot or copy to share.
            </p>

            <div class="flex gap-2">
              <input
                type="text"
                value=${seed}
                onInput=${(e) => setSeed(e.target.value)}
                onKeyDown=${onKeyDown}
                placeholder="Enter a seed (or leave blank for random)"
                class="flex-1 px-3 py-2 rounded border font-mono text-sm transition-colors duration-300 outline-none"
                style=${{
                  backgroundColor: theme.userMessageBackground,
                  color: theme.text,
                  borderColor: theme.inactive,
                }}
              />
              <button
                onClick=${generate}
                class="px-4 py-2 rounded font-mono text-sm font-bold transition-colors duration-300 cursor-pointer"
                style=${{ backgroundColor: theme.claude, color: theme.inverseText }}
              >Hatch</button>
              <button
                onClick=${randomize}
                class="px-4 py-2 rounded font-mono text-sm transition-colors duration-300 cursor-pointer border"
                style=${{ borderColor: theme.inactive, color: theme.text }}
                title="Random seed"
              >🎲</button>
            </div>

            ${result && html`
              <div class="flex flex-col items-center gap-3">
                <${TradingCard} bones=${result.bones} seed=${result.seed} />
                <div class="flex gap-2 items-center">
                  <button
                    onClick=${onCopy}
                    class="px-3 py-1.5 rounded font-mono text-xs transition-colors duration-300 cursor-pointer border"
                    style=${{ borderColor: theme.inactive, color: theme.text }}
                  >${copied ? 'Copied!' : 'Copy as text'}</button>
                  <span class="font-mono text-xs" style=${{ color: theme.inactive }}>
                    seed: ${result.seed.length > 24 ? result.seed.slice(0, 24) + '...' : result.seed}
                  </span>
                </div>
              </div>
            `}

            <details class="mt-4">
              <summary
                class="cursor-pointer font-mono text-sm select-none"
                style=${{ color: theme.inactive }}
              >Browse all species</summary>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mt-4">
                ${SPECIES.map(species => {
                  const previewBones = { species, eye: '·', hat: 'none', rarity: 'common', shiny: false, stats: {} };
                  return html`
                    <div
                      key=${species}
                      class="rounded border p-3 flex flex-col items-center gap-1 transition-colors duration-300 cursor-pointer"
                      style=${{ borderColor: theme.subtle, backgroundColor: theme.subtle }}
                      onClick=${() => { setSeed(species); setSeedInURL(species); const { bones } = roll(species); setResult({ bones, seed: species }); setCopied(false); }}
                    >
                      <pre
                        class="font-mono text-xs leading-tight select-none"
                        style=${{ color: theme.text }}
                      >${renderSprite(previewBones, 0).join('\n')}</pre>
                      <span class="font-mono text-xs" style=${{ color: theme.inactive }}>${species}</span>
                    </div>
                  `;
                })}
              </div>
            </details>
          </div>
        `;
      }

      render(
        html`<${BuddyCreator} />`,
        document.getElementById("buddy-app"),
      );
      // #endregion
    </script>
  </head>
  <body
    class="transition-colors duration-300"
    style="background-color: var(--bg); color: var(--text);"
  >
    <nav class="p-4">
      <a
        href="/experiments"
        class="inline-flex items-center gap-1 transition-colors duration-300"
        style="color: var(--text);"
        ><Experimental />Back to /experiments</a
      >
    </nav>
    <main class="max-w-2xl mx-auto p-4">
      <div class="flex items-baseline justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold">Claude Code Buddy Creator</h1>
        <div id="theme-switcher"></div>
      </div>
      <div id="buddy-app"></div>
    </main>

  </body>
</html>
