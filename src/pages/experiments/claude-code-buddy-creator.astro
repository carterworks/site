            return lightTheme;
          case "light-daltonized":
            return lightDaltonizedTheme;
          case "dark-daltonized":
            return darkDaltonizedTheme;
          default:
            return darkTheme;
        }
      }
      // #endregion
      // Port of https://github.com/chatgptprojects/claude-code/blob/642c7f944bbe5f7e57c05d756ab7fa7c9c5035cc/src/buddy/types.ts ---
      // #region:data
      const RARITIES = ["common", "uncommon", "rare", "epic", "legendary"];
      /** @typedef {(typeof RARITIES)[number]} Rarity */

      // One species name collides with a model-codename canary in excluded-strings.txt.
      // The check greps build output (not source), so runtime-constructing the value keeps
      // the literal out of the bundle while the check stays armed for the actual codename.
      // All species encoded uniformly; `as` casts are type-position only (erased pre-bundle).
      const c = String.fromCharCode;
      // biome-ignore format: keep the species list compact

      const duck = c(0x64, 0x75, 0x63, 0x6b);
      const goose = c(0x67, 0x6f, 0x6f, 0x73, 0x65);
      const blob = c(0x62, 0x6c, 0x6f, 0x62);
      const cat = c(0x63, 0x61, 0x74);
      const dragon = c(0x64, 0x72, 0x61, 0x67, 0x6f, 0x6e);
      const octopus = c(0x6f, 0x63, 0x74, 0x6f, 0x70, 0x75, 0x73);
      const owl = c(0x6f, 0x77, 0x6c);
      const penguin = c(0x70, 0x65, 0x6e, 0x67, 0x75, 0x69, 0x6e);
      const turtle = c(0x74, 0x75, 0x72, 0x74, 0x6c, 0x65);
      const snail = c(0x73, 0x6e, 0x61, 0x69, 0x6c);
      const ghost = c(0x67, 0x68, 0x6f, 0x73, 0x74);
      const axolotl = c(0x61, 0x78, 0x6f, 0x6c, 0x6f, 0x74, 0x6c);
      const capybara = c(0x63, 0x61, 0x70, 0x79, 0x62, 0x61, 0x72, 0x61);
      const cactus = c(0x63, 0x61, 0x63, 0x74, 0x75, 0x73);
      const robot = c(0x72, 0x6f, 0x62, 0x6f, 0x74);
      const rabbit = c(0x72, 0x61, 0x62, 0x62, 0x69, 0x74);
      const mushroom = c(0x6d, 0x75, 0x73, 0x68, 0x72, 0x6f, 0x6f, 0x6d);
      const chonk = c(0x63, 0x68, 0x6f, 0x6e, 0x6b);

      const SPECIES = [
        duck,
        goose,
        blob,
        cat,
        dragon,
        octopus,
        owl,
        penguin,
        turtle,
        snail,
        ghost,
        axolotl,
        capybara,
        cactus,
        robot,
        rabbit,
        mushroom,
        chonk,
      ];
      /** @typedef {(typeof SPECIES)[number]} Species */

      const EYES = ["·", "✦", "×", "◉", "@", "°"];
      /** @typedef {(typeof EYES)[number]} Eye */

      const HATS = [
        "none",
        "crown",
        "tophat",
        "propeller",
        "halo",
        "wizard",
        "beanie",
        "tinyduck",
      ];
      /** @typedef {(typeof HATS)[number]} Hat */

      const STAT_NAMES = ["DEBUGGING", "PATIENCE", "CHAOS", "WISDOM", "SNARK"];
      /** @typedef {(typeof STAT_NAMES)[number]} StatName */

      /**
       * Deterministic parts — derived from hash(userId)
       * @typedef {Object} CompanionBones
       * @property {Rarity} rarity
       * @property {Species} species
       * @property {Eye} eye
       * @property {Hat} hat
       * @property {boolean} shiny
       * @property {Record<StatName, number>} stats
       */

      /**
       * Model-generated soul — stored in config after first hatch
       * @typedef {Object} CompanionSoul
       * @property {string} name
       * @property {string} personality
       */

      /** @typedef {CompanionBones & CompanionSoul & { hatchedAt: number }} Companion */

      /**
       * What actually persists in config. Bones are regenerated from hash(userId)
       * on every read so species renames don't break stored companions and users
       * can't edit their way to a legendary.
       * @typedef {CompanionSoul & { hatchedAt: number }} StoredCompanion
       */

      const RARITY_WEIGHTS = {
        common: 60,
        uncommon: 25,
        rare: 10,
        epic: 4,
        legendary: 1,
      };

      const RARITY_STARS = {
        common: "★",
        uncommon: "★★",
        rare: "★★★",
        epic: "★★★★",
        legendary: "★★★★★",
      };

      const RARITY_COLORS = {
        common: "inactive",
        uncommon: "success",
        rare: "permission",
        epic: "autoAccept",
        legendary: "warning",
      };
      // #endregion

      const THEME_LABELS = {
        dark: "Dark",
        light: "Light",
        "dark-daltonized": "Dark (colorblind)",
        "light-daltonized": "Light (colorblind)",
      };

      function applyTheme(themeName) {
        const theme = getTheme(themeName);
        const root = document.documentElement;
        root.style.setProperty("--bg", theme.userMessageBackground);
        root.style.setProperty("--text", theme.text);
        root.style.setProperty("--claude", theme.claude);
        root.style.setProperty("--subtle", theme.subtle);
        root.style.setProperty("--inactive", theme.inactive);
      }

      function ThemeSwitcher() {
        const [selected, setSelected] = useState("dark");

        const onChange = (e) => {
          const name = e.target.value;
          setSelected(name);
          applyTheme(name);
        };

        return html`
          <label class="flex items-center gap-2 text-sm">
            Theme
            <select
              value=${selected}
              onChange=${onChange}
              class="bg-[var(--bg)] text-[var(--text)] border border-[var(--inactive)] rounded px-2 py-1 text-sm transition-colors duration-300"
            >
              ${THEME_NAMES.map(
                (name) => html`
                  <option
                    key=${name}
                    value=${name}
                  >
                    ${THEME_LABELS[name]}
                  </option>
                `,
              )}
            </select>
          </label>
        `;
      }

      applyTheme("dark");
      render(
        html`<${ThemeSwitcher} />`,
        document.getElementById("theme-switcher"),
      );
    </script>
  </head>
  <body
    class="transition-colors duration-300"
    style="background-color: var(--bg); color: var(--text);"
  >
    <nav class="p-4">
      <a
        href="/experiments"
        class="inline-flex items-center gap-1 transition-colors duration-300"
        style="color: var(--text);"
        ><Experimental />Back to /experiments</a
      >
    </nav>
    <main class="p-4">
      <div class="flex items-baseline justify-between gap-4 mb-4">
        <h1 class="text-2xl font-bold">Claude Code Buddy Creator</h1>
        <div id="theme-switcher"></div>
      </div>
    </main>
  </body>
</html>
