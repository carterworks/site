    <style>
      :root {
        --color-paper: oklch(0.9735 0.026 90.1);
        --color-ink: oklch(25% 0.029 221.9);
        --color-panel: color-mix(in srgb, var(--color-paper) 93%, white);
        --color-line: color-mix(in srgb, var(--color-ink) 16%, transparent);
        --color-soft: color-mix(in srgb, var(--color-ink) 8%, transparent);
        --color-accent: oklch(59% 0.16 248);
        --font-sans: Optima, Candara, "Noto Sans", source-sans-pro, sans-serif;
        --font-serif:
          Didot, "Bodoni MT", "Noto Serif Display", "URW Palladio L", P052,
          Sylfaen, serif;
        --font-mono:
          "Geist Mono", ui-monospace, "Cascadia Code", "Source Code Pro", Menlo,
          Consolas, "DejaVu Sans Mono", monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        color-scheme: light dark;
      }

      body {
        margin: 0;
        color: var(--color-ink);
        background:
          radial-gradient(
            circle at top,
            rgb(255 255 255 / 0.7),
            transparent 32%
          ),
          linear-gradient(180deg, #f8f0df 0%, #f4eddf 100%);
        font-family: var(--font-sans);
      }

      a,
      a:visited {
        color: inherit;
      }

      h1,
      h2,
      h3,
      pre {
        margin: 0;
      }

      code,
      textarea,
      input,
      button {
        font: inherit;
      }

      .page {
        width: min(1180px, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 1rem 0 2rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 1rem;
        text-decoration: none;
        opacity: 0.8;
      }

      .back-link:hover {
        opacity: 1;
      }

      .hero {
        margin-bottom: 1.25rem;
      }

      .hero > * + * {
        margin-top: 0.65rem;
      }

      .hero h1 {
        margin-bottom: 0.5rem;
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4vw, 3.1rem);
        font-weight: 400;
        line-height: 1;
      }

      .hero p {
        max-width: 54rem;
        line-height: 1.5;
        opacity: 0.84;
      }

      .layout {
        display: grid;
        grid-template-columns: minmax(18rem, 27rem) minmax(0, 1fr);
        gap: 1rem;
        align-items: start;
      }

      .panel {
        border: 1px solid var(--color-line);
        border-radius: 1rem;
        background: rgb(255 255 255 / 0.68);
        box-shadow: 0 22px 44px rgb(34 30 20 / 0.07);
        backdrop-filter: blur(14px);
      }

      .controls {
        padding: 1rem;
      }

      .controls-grid {
        display: grid;
        gap: 1rem;
      }

      .controls-grid section,
      .viewer,
      .viewer-head > div,
      .error-block {
        display: flow-root;
      }

      .controls-grid section > * + *,
      .viewer > * + *,
      .viewer-head > div > * + *,
      .error-block > * + * {
        margin-top: 0.8rem;
      }

      .section-title {
        font-family: var(--font-serif);
        font-size: 1.3rem;
        font-weight: 400;
        text-wrap: balance;
      }

      .section-copy {
        line-height: 1.45;
        opacity: 0.8;
        max-width: 58ch;
        text-wrap: pretty;
      }

      .mini-example {
        border: 1px solid var(--color-line);
        border-radius: 0.8rem;
        padding: 0.8rem;
        background: color-mix(in srgb, var(--color-paper) 92%, white);
        font-family: var(--font-mono);
        font-size: 0.73rem;
        line-height: 1.5;
        white-space: pre-wrap;
      }

      .field-label {
        display: block;
        width: 100%;
      }

      .field-label span:first-child {
        font-size: 0.84rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
      }

      .field-hint {
        display: block;
        margin-top: 0.2rem;
        font-size: 0.72rem;
        opacity: 0.7;
      }

      textarea {
        display: block;
        width: 100%;
        min-height: 20rem;
        resize: vertical;
        border: 1px solid var(--color-line);
        border-radius: 1rem;
        padding: 1rem 1.05rem;
        color: inherit;
        background: linear-gradient(
          180deg,
          rgb(255 255 255 / 0.92),
          rgb(250 246 240 / 0.88)
        );
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.7),
          0 1px 2px rgb(24 24 32 / 0.06);
        font-family: var(--font-mono);
        font-size: 0.9rem;
        line-height: 1.65;
        tab-size: 2;
      }

      #paths {
        min-height: 14rem;
      }

      textarea:focus-visible {
        border-color: color-mix(in srgb, var(--color-accent) 42%, white);
        outline: 3px solid
          color-mix(in srgb, var(--color-accent) 20%, transparent);
        outline-offset: 2px;
        box-shadow:
          inset 0 1px 0 rgb(255 255 255 / 0.75),
          0 0 0 0.4rem color-mix(in srgb, var(--color-accent) 10%, transparent);
      }

      .viewer {
        padding: 1rem;
      }

      .viewer-head {
