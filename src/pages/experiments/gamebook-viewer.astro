      <header class="hero">
        <h1>Gamebook Viewer</h1>
        <p>
          Paste a branching gamebook map in the choice DSL, then enter one or
          more path strings such as <code>ABAACAAA</code>. The diagram renders
          all possible branches, then overlays the actual routes and counts how
          many reached each ending.
        </p>
      </header>

      <div id="gamebook-viewer-root"></div>
    </main>

    <script type="module" is:inline>
      import { h, render } from "https://esm.sh/preact@10";
      import { useMemo, useState } from "https://esm.sh/preact@10/hooks";
      import htm from "https://esm.sh/htm@3";

      const html = htm.bind(h);

