---
import GamebookViewerApp from "../../components/GamebookViewer.jsx";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta
      name="theme-color"
      content="#fdf6e3"
    />
    <meta
      name="color-scheme"
      content="light dark"
    />
    <meta
      http-equiv="X-UA-Compatible"
      content="ie=edge"
    />
    <link
      rel="canonical"
      href={Astro.url}
    />
    <meta
      property="og:url"
      content={Astro.url}
    />
    <meta
      property="og:locale"
      content="en_US"
    />
    <meta
      property="og:site_name"
      content="Carter McBride"
    />
    <meta
      property="og:title"
      content="Gamebook Viewer"
    />
    <meta
      property="og:type"
      content="website"
    />
    <link
      rel="icon"
      href="/favicon.svg"
      type="image/svg+xml"
    />
    <link
      rel="manifest"
      href="/manifest.webmanifest"
    />
    <link
      rel="sitemap"
      href="/sitemap-index.xml"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap"
    />

    <title>Gamebook Viewer | carter.works</title>

    <style>
      :root {
        --color-paper: oklch(0.9735 0.026 90.1);
        --color-ink: oklch(25% 0.029 221.9);
        --color-panel: color-mix(in srgb, var(--color-paper) 93%, white);
        --color-line: color-mix(in srgb, var(--color-ink) 16%, transparent);
        --color-soft: color-mix(in srgb, var(--color-ink) 8%, transparent);
        --color-accent: oklch(59% 0.16 248);
        --font-sans: Optima, Candara, "Noto Sans", source-sans-pro, sans-serif;
        --font-serif:
          Didot, "Bodoni MT", "Noto Serif Display", "URW Palladio L", P052,
          Sylfaen, serif;
        --font-mono:
          "Geist Mono", ui-monospace, "Cascadia Code", "Source Code Pro", Menlo,
          Consolas, "DejaVu Sans Mono", monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        color-scheme: light dark;
      }

      body {
        margin: 0;
        color: var(--color-ink);
        background:
          radial-gradient(
            circle at top,
            rgb(255 255 255 / 0.7),
            transparent 32%
          ),
          linear-gradient(180deg, #f8f0df 0%, #f4eddf 100%);
        font-family: var(--font-sans);
      }

      a,
      a:visited {
        color: inherit;
      }

      h1,
      h2,
      h3,
      h4,
      pre {
        margin: 0;
      }

      code,
      textarea,
      input,
      button {
        font: inherit;
      }

      .page {
        width: min(1180px, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 1rem 0 2rem;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 1rem;
        text-decoration: none;
        opacity: 0.8;
      }

      .back-link:hover {
        opacity: 1;
      }

      .hero {
        margin-bottom: 1.25rem;
      }

      .hero > * + * {
        margin-top: 0.65rem;
      }

      .hero h1 {
        margin-bottom: 0.5rem;
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4vw, 3.1rem);
        font-weight: 400;
        line-height: 1;
      }

      .hero p {
        max-width: 54rem;
        line-height: 1.5;
        opacity: 0.84;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-paper: oklch(26% 0.02 80);
          --color-ink: oklch(92% 0.02 95);
          --color-panel: rgb(28 28 31 / 0.86);
          --color-line: rgb(255 255 255 / 0.12);
          --color-soft: rgb(255 255 255 / 0.06);
        }

        body {
          background:
            radial-gradient(
              circle at top,
              rgb(255 255 255 / 0.05),
              transparent 26%
            ),
            linear-gradient(180deg, #161518 0%, #0d0d10 100%);
        }
      }
    </style>
  </head>
  <body>
    <main class="page">
      <a
        href="/experiments"
        class="back-link"
      >
        <span aria-hidden="true">&larr;</span>
        Back to /experiments
      </a>

      <header class="hero">
        <h1>Gamebook Viewer</h1>
        <p>
          Paste a branching gamebook map in the choice DSL, then enter one or
          more path strings such as <code>ABAACAAA</code>. React Flow renders
          the graph, ELK computes the layout from the real card sizes, and
          clicking a node opens its full content.
        </p>
      </header>

      <GamebookViewerApp client:only="react" />
    </main>
  </body>
</html>
