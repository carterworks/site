        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        min-height: 2rem;
        border: 1px solid var(--color-line);
        border-radius: 999px;
        padding: 0.35rem 0.7rem;
        background: rgb(255 255 255 / 0.75);
        font-size: 0.8rem;
      }

      .path-pill {
        max-width: 100%;
      }

      .path-pill code {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .swatch {
        width: 0.72rem;
        height: 0.72rem;
        border-radius: 999px;
        flex: none;
      }

      .path-status {
        opacity: 0.75;
      }

      .error-block {
        border: 1px solid rgb(160 38 38 / 0.25);
        border-radius: 0.9rem;
        padding: 0.8rem 0.9rem;
        color: rgb(107 23 23);
        background: rgb(255 237 237 / 0.7);
      }

      .error-block h3 {
        font-size: 0.95rem;
      }

      .error-list {
        margin: 0;
        padding-left: 1.1rem;
        line-height: 1.5;
      }

      #gamebook-path {
        overflow: auto;
        max-height: clamp(30rem, 74vh, 58rem);
        border: 1px solid var(--color-line);
        border-radius: 1rem;
        background: linear-gradient(
          180deg,
          rgb(255 255 255 / 0.82),
          rgb(249 244 236 / 0.95)
        );
      }

      .diagram-shell {
        min-width: max-content;
        padding: 1rem;
      }

      .diagram-empty {
        display: grid;
        place-items: center;
        min-height: 16rem;
        padding: 1rem;
        text-align: center;
        opacity: 0.72;
      }

      .legend-note {
        font-size: 0.77rem;
        line-height: 1.5;
        opacity: 0.72;
        max-width: 70ch;
        text-wrap: pretty;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (max-width: 980px) {
        .layout {
          grid-template-columns: 1fr;
        }

        #gamebook-path {
          max-height: 62vh;
        }
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-paper: oklch(26% 0.02 80);
          --color-ink: oklch(92% 0.02 95);
          --color-panel: rgb(28 28 31 / 0.86);
          --color-line: rgb(255 255 255 / 0.12);
          --color-soft: rgb(255 255 255 / 0.06);
        }

        body {
          background:
            radial-gradient(
              circle at top,
              rgb(255 255 255 / 0.05),
              transparent 26%
            ),
            linear-gradient(180deg, #161518 0%, #0d0d10 100%);
        }

        .panel,
        textarea,
        .pill,
        .path-pill,
        .mini-example,
        #gamebook-path {
          background: rgb(23 23 28 / 0.84);
        }

        textarea {
          background: linear-gradient(
            180deg,
            rgb(32 32 38 / 0.96),
            rgb(20 20 26 / 0.92)
          );
          box-shadow:
            inset 0 1px 0 rgb(255 255 255 / 0.04),
            0 1px 2px rgb(0 0 0 / 0.25);
        }

        .error-block {
          color: rgb(255 208 208);
          background: rgb(89 22 22 / 0.34);
        }
      }
    </style>
