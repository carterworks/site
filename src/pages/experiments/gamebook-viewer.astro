      const DEFAULT_PATHS = `ABAACAAA\nBABAABAB\nABACACABB`;
      const PATH_COLORS = [
        "#4063ff",
        "#d54b9a",
        "#0f9f84",
        "#e07c24",
        "#8b5cf6",
        "#d44f42",
        "#0084b8",
        "#7a9b1d",
      ];
      const EVENT_LINE_RE = /^(\d+)\.\s*(.*)$/;
      const CHOICE_LINE_RE = /^([A-Z])\((\d+)\)\.\s*(.*)$/;
      const NODE_WIDTH = 220;
      const EVENT_HEIGHT = 88;
      const TERMINAL_HEIGHT = 72;
      const PAD_X = 40;
      const PAD_Y = 36;
      const GAP_X = 42;
      const GAP_Y = 112;

      /**
       * @param {number} id
       * @param {string} title
       * @param {{ marker: string, targetId: number, text: string, lineNumber: number }[]} choices
       * @param {number} lineNumber
       */
      function createEvent(id, title, choices, lineNumber) {
        return { id, title, choices, lineNumber };
      }

      /**
       * @param {string} sourceText
       */
      function parseChoiceDsl(sourceText) {
        const lines = sourceText.replace(/\r/g, "").split("\n");
        /** @type {Map<number, ReturnType<typeof createEvent>>} */
        const events = new Map();
        /** @type {string[]} */
        const errors = [];
        let lineIndex = 0;
        let firstEventId = null;

        while (lineIndex < lines.length) {
          const rawLine = lines[lineIndex].trim();
          if (!rawLine) {
            lineIndex += 1;
            continue;
          }

          const eventMatch = rawLine.match(EVENT_LINE_RE);
          if (!eventMatch) {
            errors.push(
              `Line ${lineIndex + 1}: expected an event like "17. SCHOOL BUS".`,
            );
            lineIndex += 1;
            continue;
          }

          const eventId = Number(eventMatch[1]);
          const title = eventMatch[2].trim();
          if (events.has(eventId)) {
            errors.push(
              `Line ${lineIndex + 1}: event ${eventId} is defined more than once.`,
            );
          }
          if (firstEventId === null) firstEventId = eventId;
          lineIndex += 1;

          /** @type {ReturnType<typeof createEvent>["choices"]} */
          const choices = [];
          const seenMarkers = new Set();

          while (lineIndex < lines.length) {
            const choiceLine = lines[lineIndex].trim();
            if (!choiceLine) {
              lineIndex += 1;
              break;
            }
            if (EVENT_LINE_RE.test(choiceLine)) break;

            const choiceMatch = choiceLine.match(CHOICE_LINE_RE);
            if (!choiceMatch) {
              errors.push(
                `Line ${lineIndex + 1}: expected a choice like "A(38). Go to art".`,
              );
              lineIndex += 1;
              continue;
            }

            const marker = choiceMatch[1];
            const targetId = Number(choiceMatch[2]);
            const text = choiceMatch[3].trim();

            if (seenMarkers.has(marker)) {
              errors.push(
                `Line ${lineIndex + 1}: event ${eventId} repeats choice ${marker}.`,
              );
            }
            seenMarkers.add(marker);

            choices.push({
              marker,
              targetId,
              text,
              lineNumber: lineIndex + 1,
            });
            lineIndex += 1;
          }

          if (choices.length === 0) {
            errors.push(
              `Line ${lineIndex}: event ${eventId} must have at least one choice.`,
            );
          }

          if (!events.has(eventId)) {
            events.set(
              eventId,
              createEvent(eventId, title, choices, lineIndex + 1),
            );
          }
        }

        if (events.size === 0) {
          errors.push(
            "No events found. Add at least one event and one choice.",
          );
        }

        return {
          ok: errors.length === 0,
          errors,
          graph: {
            events,
            rootId: events.has(1) ? 1 : firstEventId,
          },
        };
      }

      /**
       * @param {number} fromId
       * @param {number} toId
       * @param {string} marker
       */
      function edgeKey(fromId, toId, marker) {
        return `${fromId}:${marker}:${toId}`;
      }

      /**
       * @param {string} text
       */
      function parsePathInputs(text) {
        return text
          .replace(/\r/g, "")
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean)
          .map((raw, index) => ({ raw, normalized: raw.toUpperCase(), index }));
      }

      /**
       * @param {{ events: Map<number, ReturnType<typeof createEvent>>, rootId: number | null }} graph
       * @param {{ raw: string, normalized: string, index: number }} pathInput
       */
      function tracePath(graph, pathInput) {
        const { events, rootId } = graph;
        const normalized = pathInput.normalized;
        const invalidMatch = normalized.match(/[^A-Z]/);

        if (rootId === null) {
          return {
            ...pathInput,
            status: "invalid",
            message: "No root event available.",
            nodeIds: [],
            edgeKeys: [],
            finalId: null,
          };
        }

        if (invalidMatch) {
          return {
            ...pathInput,
            status: "invalid",
            message: `Contains invalid character \"${invalidMatch[0]}\". Use letters only.`,
            nodeIds: [rootId],
            edgeKeys: [],
            finalId: rootId,
          };
        }

        let currentId = rootId;
        const nodeIds = [currentId];
        const edgeKeys = [];

        for (let stepIndex = 0; stepIndex < normalized.length; stepIndex += 1) {
          const marker = normalized[stepIndex];
          const event = events.get(currentId);

          if (!event) {
            return {
              ...pathInput,
              status: "invalid",
              message: `Step ${stepIndex + 1}: path continues after ending ${currentId}.`,
              nodeIds,
              edgeKeys,
              finalId: currentId,
            };
          }

          const choice = event.choices.find((entry) => entry.marker === marker);
          if (!choice) {
            return {
              ...pathInput,
              status: "invalid",
              message: `Step ${stepIndex + 1}: event ${currentId} has no ${marker} choice.`,
              nodeIds,
              edgeKeys,
              finalId: currentId,
            };
          }

          edgeKeys.push(edgeKey(currentId, choice.targetId, choice.marker));
          currentId = choice.targetId;
          nodeIds.push(currentId);
        }

        if (events.has(currentId)) {
          return {
            ...pathInput,
            status: "in-progress",
            message: `Stops at event ${currentId} before reaching an ending.`,
            nodeIds,
            edgeKeys,
            finalId: currentId,
          };
        }

        return {
          ...pathInput,
          status: "ending",
          message: `Reached ending ${currentId}.`,
          nodeIds,
          edgeKeys,
          finalId: currentId,
        };
      }

      /**
       * @param {string} text
       * @param {number} maxCharsPerLine
       */
      function wrapText(text, maxCharsPerLine) {
        if (!text) return [""];
        const words = text.split(/\s+/).filter(Boolean);
        if (words.length === 0) return [""];

        const lines = [];
        let currentLine = words[0];
        for (let index = 1; index < words.length; index += 1) {
          const nextWord = words[index];
          if (`${currentLine} ${nextWord}`.length <= maxCharsPerLine) {
            currentLine += ` ${nextWord}`;
            continue;
          }
          lines.push(currentLine);
          currentLine = nextWord;
        }
        lines.push(currentLine);
        return lines;
      }

      /**
       * @param {{ events: Map<number, ReturnType<typeof createEvent>>, rootId: number | null }} graph
       */
      function buildDiagram(graph) {
        const { events, rootId } = graph;
        /** @type {Map<number, { id: number, kind: "event" | "ending", title: string, lines: string[], depth: number, order: number, width: number, height: number, x: number, y: number }>} */
        const nodes = new Map();
        /** @type {{ fromId: number, toId: number, marker: string, text: string, key: string }[]} */
        const edges = [];
        /** @type {Map<number, number>} */
        const inboundCounts = new Map();
        let visitOrder = 0;

        for (const event of events.values()) {
          nodes.set(event.id, {
            id: event.id,
            kind: "event",
            title: event.title || `Event ${event.id}`,
            lines: wrapText(event.title || `Event ${event.id}`, 20),
            depth: Number.POSITIVE_INFINITY,
            order: visitOrder,
            width: NODE_WIDTH,
            height: EVENT_HEIGHT,
            x: 0,
            y: 0,
          });
          visitOrder += 1;

          for (const choice of event.choices) {
            inboundCounts.set(
              choice.targetId,
              (inboundCounts.get(choice.targetId) ?? 0) + 1,
            );
            if (!nodes.has(choice.targetId) && !events.has(choice.targetId)) {
              nodes.set(choice.targetId, {
                id: choice.targetId,
                kind: "ending",
                title: `Ending ${choice.targetId}`,
                lines: wrapText(`Ending ${choice.targetId}`, 18),
                depth: Number.POSITIVE_INFINITY,
                order: visitOrder,
                width: NODE_WIDTH,
                height: TERMINAL_HEIGHT,
                x: 0,
                y: 0,
              });
              visitOrder += 1;
            }

            edges.push({
              fromId: event.id,
              toId: choice.targetId,
              marker: choice.marker,
              text: choice.text,
              key: edgeKey(event.id, choice.targetId, choice.marker),
            });
          }
        }

        const rootCandidates = [];
        if (rootId !== null && events.has(rootId)) {
          rootCandidates.push(rootId);
        }
        for (const eventId of events.keys()) {
          if ((inboundCounts.get(eventId) ?? 0) === 0 && eventId !== rootId) {
            rootCandidates.push(eventId);
          }
        }
        for (const eventId of [...events.keys()].sort((a, b) => a - b)) {
          if (!rootCandidates.includes(eventId)) rootCandidates.push(eventId);
        }

        let nextBaseDepth = 0;
        for (const candidateId of rootCandidates) {
          const candidateNode = nodes.get(candidateId);
          if (!candidateNode || Number.isFinite(candidateNode.depth) === true)
            continue;

          candidateNode.depth = nextBaseDepth;
          const queue = [candidateId];
          while (queue.length > 0) {
            const currentId = queue.shift();
            const currentNode = nodes.get(currentId);
            if (!currentNode) continue;

            const event = events.get(currentId);
            if (!event) continue;

            for (const choice of event.choices) {
              const childNode = nodes.get(choice.targetId);
              if (!childNode) continue;
              const nextDepth = currentNode.depth + 1;
              if (nextDepth < childNode.depth) {
                childNode.depth = nextDepth;
              }
              if (childNode.order > currentNode.order) {
                childNode.order = Math.min(
                  childNode.order,
                  currentNode.order + 0.1,
                );
              }
              if (
                !queue.includes(choice.targetId)
                && events.has(choice.targetId)
              ) {
                queue.push(choice.targetId);
              }
            }
          }

          const componentDepth = Math.max(
            nextBaseDepth,
            ...[...nodes.values()]
              .filter((node) => Number.isFinite(node.depth))
              .map((node) => node.depth),
          );
          nextBaseDepth = componentDepth + 1;
        }

        const depthBuckets = new Map();
        for (const node of nodes.values()) {
          const depth =
            Number.isFinite(node.depth) ? node.depth : nextBaseDepth;
          node.depth = depth;
          if (!depthBuckets.has(depth)) depthBuckets.set(depth, []);
          depthBuckets.get(depth).push(node);
        }

        let width = 0;
        let height = 0;
        for (const [depth, bucket] of [...depthBuckets.entries()].sort(
          (a, b) => a[0] - b[0],
        )) {
          bucket.sort((left, right) => {
            if (left.order !== right.order) return left.order - right.order;
            return left.id - right.id;
          });
          const bucketWidth =
            bucket.length * NODE_WIDTH + Math.max(0, bucket.length - 1) * GAP_X;
          width = Math.max(width, bucketWidth + PAD_X * 2);
          for (let index = 0; index < bucket.length; index += 1) {
            const node = bucket[index];
            node.x = PAD_X + index * (NODE_WIDTH + GAP_X) + NODE_WIDTH / 2;
            node.y = PAD_Y + depth * (EVENT_HEIGHT + GAP_Y) + node.height / 2;
            height = Math.max(height, node.y + node.height / 2 + PAD_Y);
          }
        }

        return {
          nodes,
          edges,
          width: Math.max(width, 720),
          height: Math.max(height, 420),
        };
      }

      /**
       * @param {{ nodes: Map<number, any>, edges: { key: string }[] }} diagram
       * @param {ReturnType<typeof tracePath>[]} traces
       */
      function summarizeTraces(diagram, traces) {
        const edgeCounts = new Map();
        const nodeCounts = new Map();
        const endingCounts = new Map();
        let invalidCount = 0;
        let inProgressCount = 0;
        let endingCount = 0;

        for (const trace of traces) {
          if (trace.status === "invalid") invalidCount += 1;
          if (trace.status === "in-progress") inProgressCount += 1;
          if (trace.status === "ending") endingCount += 1;

          for (const nodeId of trace.nodeIds) {
            nodeCounts.set(nodeId, (nodeCounts.get(nodeId) ?? 0) + 1);
          }
          for (const key of trace.edgeKeys) {
            edgeCounts.set(key, (edgeCounts.get(key) ?? 0) + 1);
          }
          if (trace.status === "ending" && trace.finalId !== null) {
            endingCounts.set(
              trace.finalId,
              (endingCounts.get(trace.finalId) ?? 0) + 1,
            );
          }
        }

        return {
          edgeCounts,
          nodeCounts,
          endingCounts,
          invalidCount,
          inProgressCount,
          endingCount,
          totalNodes: diagram.nodes.size,
          totalEdges: diagram.edges.length,
        };
      }

      /**
       * @param {{ x: number, y: number, width: number, height: number }} fromNode
       * @param {{ x: number, y: number, width: number, height: number }} toNode
       */
      function edgePath(fromNode, toNode) {
        const startX = fromNode.x;
        const startY = fromNode.y + fromNode.height / 2;
        const endX = toNode.x;
        const endY = toNode.y - toNode.height / 2;
        const controlOffset = Math.max(36, (endY - startY) * 0.55);
        return `M ${startX} ${startY} C ${startX} ${startY + controlOffset}, ${endX} ${endY - controlOffset}, ${endX} ${endY}`;
      }

      /**
       * @param {{ key: string, fromId: number, toId: number, marker: string, text: string }} edge
       * @param {Map<number, any>} nodes
       */
      function edgeLabelPosition(edge, nodes) {
        const fromNode = nodes.get(edge.fromId);
        const toNode = nodes.get(edge.toId);
        if (!fromNode || !toNode) return { x: 0, y: 0 };
        const x = (fromNode.x + toNode.x) / 2;
        const y =
          (fromNode.y + fromNode.height / 2 + toNode.y - toNode.height / 2) / 2;
        return { x, y };
      }

      function App() {
        const [choicesText, setChoicesText] = useState(DEFAULT_CHOICES);
        const [pathsText, setPathsText] = useState(DEFAULT_PATHS);

        const parsed = useMemo(
          () => parseChoiceDsl(choicesText),
          [choicesText],
        );
        const diagram = useMemo(
          () => (parsed.ok ? buildDiagram(parsed.graph) : null),
          [parsed],
        );
        const pathInputs = useMemo(
          () => parsePathInputs(pathsText),
          [pathsText],
        );
        const traces = useMemo(
          () =>
            parsed.ok ?
              pathInputs.map((entry) => tracePath(parsed.graph, entry))
            : [],
          [parsed, pathInputs],
        );
        const summary = useMemo(
          () => (diagram ? summarizeTraces(diagram, traces) : null),
          [diagram, traces],
        );

        return html`
          <div class="layout">
            <section class="panel controls">
              <div class="controls-grid">
                <section>
                  <h2 class="section-title">Choices</h2>
                  <p class="section-copy">
                    Each event starts with <code>number. title</code>, followed
                    by one or more choices like <code>A(27). description</code>.
                  </p>
                  <div class="mini-example">
                    1. ROAD TRIP A(27). Call her dad and get picked up B(17).
                    Brave the bus alone 17. SCHOOL BUS A(38). Skip honors
                    history and go to art B(46). Keep the honors history class
                  </div>
                  <label
                    for="choices"
                    class="field-label"
                  >
                    <span>Choice DSL</span>
                    <span class="field-hint">Example map preloaded</span>
                  </label>
                  <textarea
                    id="choices"
                    spellcheck=${false}
                    value=${choicesText}
                    onInput=${(event) =>
                      setChoicesText(event.currentTarget.value)}
                  />
                </section>

                <section>
                  <h2 class="section-title">Paths</h2>
                  <p class="section-copy">
                    One path per line. Letters are followed from the root event.
                    Completed paths count toward the endings they reach.
                  </p>
                  <label
                    for="paths"
                    class="field-label"
                  >
                    <span>Path Inputs</span>
                    <span class="field-hint">Example: ABAACAAA</span>
                  </label>
                  <textarea
                    id="paths"
                    spellcheck=${false}
                    value=${pathsText}
                    onInput=${(event) =>
                      setPathsText(event.currentTarget.value)}
                  />
                </section>
              </div>
            </section>

            <section class="panel viewer">
              <div class="viewer-head">
                <div>
                  <h2 class="section-title">Path Diagram</h2>
                  <p>
                    The full graph shows every branch in the DSL. Colored
                    overlays show the submitted routes, and ending badges count
                    how many completed paths landed there.
                  </p>
                </div>
                ${summary ?
                  html`
                    <div
                      class="summary-row"
                      aria-label="Diagram summary"
                    >
                      <div class="pill">${summary.totalNodes} nodes</div>
                      <div class="pill">${summary.totalEdges} choices</div>
                      <div class="pill">
                        ${summary.endingCount} endings reached
                      </div>
                      <div class="pill">
                        ${summary.inProgressCount} still in progress
                      </div>
                      <div class="pill">${summary.invalidCount} invalid</div>
                    </div>
                  `
                : null}
              </div>

              ${parsed.errors.length > 0 ?
                html`
                  <div
                    class="error-block"
                    role="alert"
                  >
                    <h3>DSL parse errors</h3>
                    <ul class="error-list">
                      ${parsed.errors.map(
                        (error) => html`<li key=${error}>${error}</li>`,
                      )}
                    </ul>
                  </div>
                `
              : null}
              ${traces.length > 0 ?
                html`
                  <div
                    class="path-list"
                    aria-label="Path outcomes"
                  >
                    ${traces.map((trace, index) => {
                      const color = PATH_COLORS[index % PATH_COLORS.length];
                      return html`
                        <div
                          class="path-pill"
                          key=${`${trace.raw}-${index}`}
                        >
                          <span
                            class="swatch"
                            style=${`background:${color}`}
                            aria-hidden="true"
                          ></span>
                          <code>${trace.raw}</code>
                          <span class="path-status">${trace.message}</span>
                        </div>
                      `;
                    })}
                  </div>
                `
              : null}

              <div id="gamebook-path">
                ${diagram && summary ?
                  html`
                    <div class="diagram-shell">
                      <${DiagramSvg}
                        diagram=${diagram}
                        traces=${traces}
                        summary=${summary}
                      />
                    </div>
                  `
                : html`
                    <div class="diagram-empty">
                      Enter a valid DSL to render the diagram.
                    </div>
                  `}
              </div>

              <p class="legend-note">
                Undefined target ids are treated as endings. Paths that stop on
                a defined event are marked in progress. Paths that request a
                missing letter or continue past an ending are marked invalid.
              </p>
            </section>
          </div>
        `;
      }

      /**
       * @param {{ diagram: ReturnType<typeof buildDiagram>, traces: ReturnType<typeof tracePath>[], summary: ReturnType<typeof summarizeTraces> }} props
       */
      function DiagramSvg({ diagram, traces, summary }) {
        const { nodes, edges, width, height } = diagram;

        return html`
          <svg
            width=${width}
            height=${height}
            viewBox=${`0 0 ${width} ${height}`}
            role="img"
            aria-labelledby="gamebook-diagram-title gamebook-diagram-desc"
          >
            <title id="gamebook-diagram-title">Gamebook path diagram</title>
            <desc id="gamebook-diagram-desc">
              A top-to-bottom diagram of the gamebook graph with highlighted
              user paths and ending counts.
            </desc>

            <defs>
              <marker
                id="arrow-base"
                viewBox="0 0 10 10"
                refX="8"
                refY="5"
                markerWidth="6"
                markerHeight="6"
                orient="auto-start-reverse"
              >
                <path
                  d="M 0 0 L 10 5 L 0 10 z"
                  fill="rgb(84 84 94 / 0.52)"
                />
              </marker>
              ${PATH_COLORS.map(
                (color, index) => html`
                  <marker
                    id=${`arrow-${index}`}
                    key=${color}
                    viewBox="0 0 10 10"
                    refX="8"
                    refY="5"
                    markerWidth="6"
                    markerHeight="6"
                    orient="auto-start-reverse"
                  >
                    <path
                      d="M 0 0 L 10 5 L 0 10 z"
                      fill=${color}
                    />
                  </marker>
                `,
              )}
            </defs>

            <rect
              x="0"
              y="0"
              width=${width}
              height=${height}
              rx="18"
              fill="transparent"
            />

            ${edges.map((edge) => {
              const fromNode = nodes.get(edge.fromId);
              const toNode = nodes.get(edge.toId);
              if (!fromNode || !toNode) return null;

              const pathData = edgePath(fromNode, toNode);
              const label = edgeLabelPosition(edge, nodes);
              const edgeCount = summary.edgeCounts.get(edge.key) ?? 0;

              return html`
                <g key=${edge.key}>
                  <path
                    d=${pathData}
                    fill="none"
                    stroke=${edgeCount > 0 ?
                      "rgb(110 110 120 / 0.42)"
                    : "rgb(110 110 120 / 0.24)"}
                    stroke-width=${edgeCount > 0 ? 3 : 2}
                    marker-end="url(#arrow-base)"
                  />
                  <g transform=${`translate(${label.x}, ${label.y})`}>
                    <rect
                      x="-14"
                      y="-11"
                      width="28"
                      height="20"
                      rx="10"
                      fill="rgb(255 255 255 / 0.85)"
                      stroke="rgb(84 84 94 / 0.14)"
                    />
                    <text
                      text-anchor="middle"
                      dominant-baseline="middle"
                      font-family="Geist Mono, ui-monospace, monospace"
                      font-size="11"
                      fill="currentColor"
                    >
                      ${edge.marker}
                    </text>
                  </g>
                </g>
              `;
            })}
            ${traces.map((trace, traceIndex) => {
              const color = PATH_COLORS[traceIndex % PATH_COLORS.length];
              const markerId = `url(#arrow-${traceIndex % PATH_COLORS.length})`;
              return trace.edgeKeys.map((key, keyIndex) => {
                const edge = edges.find((entry) => entry.key === key);
                if (!edge) return null;
                const fromNode = nodes.get(edge.fromId);
                const toNode = nodes.get(edge.toId);
                if (!fromNode || !toNode) return null;
                return html`
                  <path
                    key=${`${trace.raw}-${key}-${keyIndex}`}
                    d=${edgePath(fromNode, toNode)}
                    fill="none"
                    stroke=${color}
                    stroke-width="4"
                    stroke-linecap="round"
                    marker-end=${markerId}
                    opacity=${trace.status === "invalid" ? 0.5 : 0.92}
                  />
                `;
              });
            })}
            ${[...nodes.values()].map((node) => {
              const nodeCount = summary.nodeCounts.get(node.id) ?? 0;
              const endingCount = summary.endingCounts.get(node.id) ?? 0;
              const isEnding = node.kind === "ending";
              const x = node.x - node.width / 2;
              const y = node.y - node.height / 2;
              const fill =
                isEnding ?
                  "color-mix(in srgb, rgb(207 237 255) 28%, white)"
                : "rgb(255 255 255 / 0.94)";
              const stroke =
                nodeCount > 0 ?
                  "rgb(46 84 187 / 0.55)"
                : "rgb(84 84 94 / 0.24)";

              return html`
                <g key=${node.id}>
                  <rect
                    x=${x}
                    y=${y}
                    width=${node.width}
                    height=${node.height}
                    rx=${isEnding ? 24 : 16}
                    fill=${fill}
                    stroke=${stroke}
                    stroke-width=${nodeCount > 0 ? 2.5 : 1.5}
                  />

                  <text
                    x=${x + 16}
                    y=${y + 18}
                    font-family="Geist Mono, ui-monospace, monospace"
                    font-size="11"
                    fill="rgb(76 76 84 / 0.82)"
                  >
                    ${isEnding ? "ENDING" : "EVENT"} ${node.id}
                  </text>

                  <text
                    x=${x + 16}
                    y=${y + 40}
                    font-family="Optima, Candara, Noto Sans, sans-serif"
                    font-size="16"
                    fill="currentColor"
                  >
                    ${node.lines.map(
                      (line, lineIndex) => html`
                        <tspan
                          key=${`${node.id}-${lineIndex}`}
                          x=${x + 16}
                          dy=${lineIndex === 0 ? 0 : 18}
                        >
                          ${line}
                        </tspan>
                      `,
                    )}
                  </text>

                  ${nodeCount > 0 ?
                    html`
                      <text
                        x=${x + node.width - 16}
                        y=${y + 18}
                        text-anchor="end"
                        font-family="Geist Mono, ui-monospace, monospace"
                        font-size="11"
                        fill="rgb(46 84 187 / 0.86)"
                      >
                        ${nodeCount} path${nodeCount === 1 ? "" : "s"}
                      </text>
                    `
                  : null}
                  ${endingCount > 0 ?
                    html`
                      <g
                        transform=${`translate(${x + node.width - 28}, ${y + node.height - 20})`}
                      >
                        <rect
                          x="-26"
                          y="-14"
                          width="52"
                          height="24"
                          rx="12"
                          fill="rgb(46 84 187)"
                        />
                        <text
                          text-anchor="middle"
                          dominant-baseline="middle"
                          font-family="Geist Mono, ui-monospace, monospace"
                          font-size="12"
                          fill="white"
                        >
                          ${endingCount} hit${endingCount === 1 ? "" : "s"}
                        </text>
                      </g>
                    `
                  : null}
                </g>
              `;
            })}
          </svg>
        `;
      }

      render(html`<${App} />`, document.getElementById("gamebook-viewer-root"));
    </script>
  </body>
</html>
