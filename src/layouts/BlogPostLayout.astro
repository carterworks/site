---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { formatDateLong } from "../lib/date";

interface Props {
  frontmatter: CollectionEntry<"blog">["data"] & {
    articleClass?: string;
  };
}

const { frontmatter } = Astro.props;
const pubDateISO = frontmatter.pubDate.toISOString();
const humanFriendlyDate = formatDateLong(frontmatter.pubDate);
---

<BaseLayout title={`${frontmatter.title} | carter.works`}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:article:published_time" content={pubDateISO} />
    <meta property="og:article:author" content="Carter McBride" />
    <style is:global>
      article img {
        max-inline-size: 100%;
        block-size: auto;
      }
    </style>
  </Fragment>
  <header>
    <a href="/">
      <strong view-transition-name="carter">
        <img
          class="inline-avatar"
          src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='32' fill='%23d9d9d9'/%3E%3Ccircle cx='32' cy='25' r='11' fill='%23888888'/%3E%3Cpath d='M14 56c2.5-10 9.5-17 18-17s15.5 7 18 17' fill='%23888888'/%3E%3C/svg%3E"
          alt="A headshot of Carter"
        />Carter McBride.
      </strong>
    </a>
  </header>
  <article class:list={["stack", frontmatter.articleClass]}>
    <header class="stack">
      <h1>
        {frontmatter.draft && "Rough Draft: "}{frontmatter.title}
      </h1>
      <p>
        <time datetime={pubDateISO}>{humanFriendlyDate}</time>
      </p>
    </header>
    <slot />
  </article>
</BaseLayout>
