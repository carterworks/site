---
import { ClientRouter } from "astro:transitions";
import NameTag from "../components/NameTag.astro";
import { getPageMetadata, type PageMetadata } from "../lib/pages";
interface Props {
  title?: string;
  class?: string;
  metadata?: PageMetadata;
}
const { class: className } = Astro.props;
const metadata = Astro.props.metadata ?? getPageMetadata(Astro.url.pathname);
const title = Astro.props.title ?? metadata?.title;
if (!title) throw new Error(`Missing page title: ${Astro.url.pathname}`);
const ogImage = metadata?.ogImage
  ? new URL(metadata.ogImage, Astro.site)
  : undefined;
const fediverseCreator = "@literallyacar@mastodon.social";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta name="fediverse:creator" content={fediverseCreator} />
    <ClientRouter />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="Carter's Blog"
      href="/blog/atom.xml"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Carter's Blog"
      href="/blog/rss.xml"
    />
    <title>{title}</title>
    {metadata?.description && <meta name="description" content={metadata.description} />}
    {metadata && <meta property="og:title" content={metadata.title} />}
    {metadata?.description && <meta property="og:description" content={metadata.description} />}
    {metadata?.ogType && <meta property="og:type" content={metadata.ogType} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:type" content="image/webp" />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {metadata && <meta property="og:image:alt" content={metadata.title} />}
    <style is:global>
      @layer reset {
        *,
        *::before,
        *::after {
          margin: 0;
          padding: 0;
          box-sizing: border-box;
        }
        :where(h1, h2, h3, h4, h5) {
          font-size: initial;
        }
        :where(img, svg, video) {
          max-inline-size: 100%;
          block-size: auto;
        }
        p {
          text-wrap: pretty;
        }
      }
      @font-face {
        font-family: InterVariable;
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
        src: url("/InterVariable.woff2") format("woff2");
      }
      @font-face {
        font-family: InterVariable;
        font-style: italic;
        font-weight: 100 900;
        font-display: swap;
        src: url("/InterVariable-Italic.woff2") format("woff2");
      }
      :root {
        --spacer: 0.25lh;
        --size-2xs: calc(var(--spacer) * 0.5);
        --size-xs: calc(var(--spacer) * 1);
        --size-sm: calc(var(--spacer) * 2);
        --size-md: calc(var(--spacer) * 4);
        --size-lg: calc(var(--size-md) * 2);
        --size-xl: calc(var(--size-md) * 4);
        --size-2xl: calc(var(--size-xl) * 2);
        --size-3xl: calc(var(--size-2xl) * 2);
        --size-screen: 100svh;
        --size-prose: 65ch;

        --color-white: oklch(98% 0 0);
        --color-black: oklch(18% 0 0);
        --color-text: light-dark(var(--color-black), var(--color-white));
        --color-bg: light-dark(var(--color-white), var(--color-black));

        scrollbar-gutter: stable;
      }
      body {
        --top-gutter-size: clamp(var(--size-md), 40svh, var(--size-3xl));

        background-color: var(--color-bg);
        color: var(--color-text);

        font-family: "InterVariable", sans-serif;
        font-optical-sizing: auto;
        line-height: 1.3;
        min-height: var(--size-screen);
        display: grid;
        grid-template:
          [top-gutter-start] "left-gutter top-gutter right-gutter" var(
            --top-gutter-size
          )
          [top-gutter-end content-row-start] "left-gutter content right-gutter" min-content
          [content-row-end bottom-gutter-start] "left-gutter bottom-gutter right-gutter" minmax(
            var(--size-md),
            1fr
          )
          [bottom-gutter-end] /
          [left-gutter-start] minmax(var(--size-md), auto)
          [left-gutter-end content-col-start] minmax(0, var(--size-prose))
          [content-col-end right-gutter-start] minmax(var(--size-md), auto)
          [right-gutter-end];
        place-content: center;

        @media (max-width: 640px) {
          --top-gutter-size: clamp(var(--size-md), 20svh, var(--size-lg));
        }
        @media (max-height: 500px) {
          --top-gutter-size: clamp(var(--size-md), 10svh, var(--size-lg));
        }

        > * {
          grid-area: content;
        }
      }
      :is(ol, ul) > li + li {
        /* match the line-height on the body */
        margin-block-start: calc(1lh - 1em);
      }
      .stack > * + * {
        margin-block-start: var(--flow-space, var(--size-md, 1lh));
      }
      a[href^="http"]:not(:has(img))::after {
        content: "↗";
        font-size: 0.8em;
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <div class="stack">
      <header>
        <NameTag href="/" />
      </header>
      <main class={className}>
        <slot />
      </main>
    </div>
  </body>
</html>
