  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "module": "src/index.astro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carterworks/site.git"
  },
  "scripts": {
    "dev": "DEV=true astro dev",
    "start": "DEV=true astro dev",
