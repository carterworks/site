    "oxfmt": "0.55.0",
    "sharp": "0.35.1",
    "takumi-js": "2.0.0-rc.9",
    "typescript": "6.0.3",
    "wrangler": "4.102.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@types/sanitize-html": "2.16.1",
    "feed": "5.2.1",
    "sanitize-html": "2.17.5",
    "satteri": "0.9.4"
  }
